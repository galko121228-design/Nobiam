<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    xmlns:tools="http://schemas.android.com/tools">

    <queries>
        <package android:name="com.mojang.minecraftpe" />
        <package android:name="com.mojang.minecraftpe.premium" />
        <package android:name="com.mojang.minecraftpe.demo" />
    </queries>

    <application
        android:name=".NobiamApplication"
        android:allowBackup="true"
        android:label="Nobiam"
        android:icon="@drawable/logo"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nobiam"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:resizeableActivity="false"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:theme="@style/Theme.Nobiam.Fullscreen">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
