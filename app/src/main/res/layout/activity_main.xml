<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
android:layout_width="match_parent"
android:layout_height="match_parent"
android:fitsSystemWindows="false"> xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#0A0E1A">

    <LinearLayout
        android:id="@+id/navPanel"
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#111827"
        android:paddingTop="24dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/navHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠"
            android:textSize="24sp"
            android:textColor="#00D4FF"
            android:background="?attr/selectableItemBackground"
            android:background="@drawable/neon_card"
android:padding="12dp"/>

        <Button
            android:id="@+id/navSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="24sp"
            android:textColor="#6B7280"
            android:background="?attr/selectableItemBackground"
            android:background="@drawable/neon_card"
android:padding="12dp"/>

        <Button
            android:id="@+id/navAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️"
            android:textSize="24sp"
            android:textColor="#6B7280"
            android:background="?attr/selectableItemBackground"
            android:background="@drawable/neon_card"
android:padding="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="v1.0"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:background="@drawable/neon_card"
android:padding="12dp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#0A0E1A"/>

</LinearLayout>
