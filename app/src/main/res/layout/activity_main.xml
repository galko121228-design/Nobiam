<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0f172a"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/Nobiam"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="nobiam_logo"
                android:textColor="#00D4FF"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_home"
            android:background="@drawable/nav_active"
            android:scaleType="center"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <ImageButton
            android:id="@+id/navSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/nav_inactive"
            android:scaleType="center"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <ImageButton
            android:id="@+id/navAbout"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_about"
            android:background="@drawable/nav_inactive"
            android:scaleType="center"
            android:padding="8dp"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0A0E1A"
        android:padding="16dp"/>

</LinearLayout>
