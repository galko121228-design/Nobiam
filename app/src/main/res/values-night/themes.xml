<resources>
    <!-- Тёмная тема (ночной режим) -->
    <style name="Theme.Nobiam" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:colorPrimary">#00D4FF</item>
    </style>

    <style name="Theme.Nobiam.Fullscreen" parent="Theme.Nobiam">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="cardStrokeColor">#2A2A2A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
